# Copy this file to .env and fill in your values
SECRET_KEY=placify-secret-key-change-me-in-production

# ── MySQL (used by config.py / db.py) ─────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=campus_placement
MYSQL_POOL_SIZE=5

# ── Also used by setup_db.py ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=campus_placement

FLASK_ENV=development
