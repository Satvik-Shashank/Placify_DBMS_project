# =============================================================================
# PLACIFY - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# --- Supabase PostgreSQL Database ---
# Go to Supabase Dashboard -> Settings -> Database -> Connection string (URI)
# Copy the values from there:
MYSQL_HOST=db.xxxxxxxxxxxx.supabase.co
MYSQL_PORT=5432
MYSQL_USER=postgres
MYSQL_PASSWORD=your-supabase-db-password
MYSQL_DATABASE=postgres
MYSQL_POOL_SIZE=3

# --- For Vercel Production ---
# Set these in Vercel Dashboard -> Settings -> Environment Variables
# FLASK_ENV=production
# SECRET_KEY=<run: python -c "import secrets; print(secrets.token_hex(32))">
